{
  "version": 1,
  "project": {
    "name": "Specwright"
  },
  "defaults": {
    "mode": "lite",
    "pack": "core",
    "onlineResearch": "auto",
    "maxContextFiles": 6,
    "maxOutputWords": 1200
  },
  "agents": {
    "researcher": {
      "model": "pi/task"
    },
    "planner": {
      "model": "pi/plan"
    },
    "executor": {
      "model": "pi/task"
    },
    "verifier": {
      "model": "pi/task"
    }
  },
  "packs": {
    "roots": [
      ".specwright/packs",
      "packs"
    ],
    "enabled": [
      "core"
    ]
  },
  "runtimes": {
    "omp": {
      "enabled": true
    }
  },
  "workflow": {
    "autoCommit": true,
    "publishMode": "none",
    "remote": "origin"
  }
}
